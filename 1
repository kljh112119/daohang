<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>星云影视 - 高清影视聚合导航</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css">
    <style>
        body { background: #0b101a; color: #fff; font-family: system-ui, sans-serif; }
        .glass { background: rgba(0,0,0,0.6); backdrop-filter: blur(12px); }
        .card { transition: all 0.3s ease; }
        .card:hover { transform: translateY(-4px); }
        img { loading: lazy; }
    </style>
</head>

<body class="min-h-screen">

<!-- 顶部导航 -->
<nav class="fixed w-full top-0 z-50 glass px-4 py-3">
    <div class="max-w-7xl mx-auto flex items-center justify-between">
        <h1 class="text-2xl font-bold text-white flex items-center gap-2">
            <i class="fa fa-film text-red-500"></i>
            <span>星云影视</span>
        </h1>
        <div class="flex gap-4">
            <button class="px-3 py-1 bg-red-600 hover:bg-red-700 rounded-md text-sm">首页</button>
            <button class="px-3 py-1 bg-gray-800 hover:bg-gray-700 rounded-md text-sm">电影</button>
            <button class="px-3 py-1 bg-gray-800 hover:bg-gray-700 rounded-md text-sm">剧集</button>
            <button class="px-3 py-1 bg-gray-800 hover:bg-gray-700 rounded-md text-sm">动漫</button>
        </div>
    </div>
</nav>

<!-- 搜索栏 -->
<div class="pt-24 pb-6 px-4">
    <div class="max-w-4xl mx-auto">
        <div class="relative">
            <input type="text" placeholder="搜索全网影视..." 
                   class="w-full px-5 py-3 bg-gray-900 border border-gray-700 rounded-full text-white pl-12 outline-none focus:border-red-500">
            <i class="fa fa-search absolute left-5 top-1/2 -translate-y-1/2 text-gray-400 text-lg"></i>
        </div>
    </div>
</div>

<!-- 轮播 -->
<div class="px-4 mb-10">
    <div class="max-w-7xl mx-auto h-[320px] md:h-[450px] rounded-2xl overflow-hidden relative">
        <img src="https://picsum.photos/id/1/1920/800" class="w-full h-full object-cover">
        <div class="absolute inset-0 bg-gradient-to-t from-black via-black/60 to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-6 md:p-10 max-w-xl">
            <h2 class="text-3xl md:text-5xl font-bold mb-3">热门影视推荐</h2>
            <p class="text-gray-300 text-lg mb-4">全网高清资源 · 极速播放</p>
            <button class="px-6 py-2 bg-red-600 rounded-full flex items-center gap-2">
                <i class="fa fa-play"></i> 立即观看
            </button>
        </div>
    </div>
</div>

<!-- 主要内容 -->
<div class="max-w-7xl mx-auto px-4 mb-16">

    <!-- 热门电影 -->
    <section class="mb-12">
        <div class="flex justify-between items-center mb-5">
            <h2 class="text-xl md:text-2xl font-semibold">热门电影</h2>
            <span class="text-gray-400 text-sm">查看更多</span>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
            <div class="card rounded-xl overflow-hidden bg-gray-900">
                <img src="https://picsum.photos/id/237/400/600" class="w-full aspect-[2/3] object-cover">
                <div class="p-3 text-center text-sm">电影标题</div>
            </div>
            <div class="card rounded-xl overflow-hidden bg-gray-900">
                <img src="https://picsum.photos/id/238/400/600" class="w-full aspect-[2/3] object-cover">
                <div class="p-3 text-center text-sm">电影标题</div>
            </div>
            <div class="card rounded-xl overflow-hidden bg-gray-900">
                <img src="https://picsum.photos/id/239/400/600" class="w-full aspect-[2/3] object-cover">
                <div class="p-3 text-center text-sm">电影标题</div>
            </div>
            <div class="card rounded-xl overflow-hidden bg-gray-900">
                <img src="https://picsum.photos/id/240/400/600" class="w-full aspect-[2/3] object-cover">
                <div class="p-3 text-center text-sm">电影标题</div>
            </div>
            <div class="card rounded-xl overflow-hidden bg-gray-900">
                <img src="https://picsum.photos/id/241/400/600" class="w-full aspect-[2/3] object-cover">
                <div class="p-3 text-center text-sm">电影标题</div>
            </div>
        </div>
    </section>

    <!-- 热门剧集 -->
    <section class="mb-12">
        <div class="flex justify-between items-center mb-5">
            <h2 class="text-xl md:text-2xl font-semibold">热门电视剧</h2>
            <span class="text-gray-400 text-sm">查看更多</span>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
            <div class="card rounded-xl overflow-hidden bg-gray-900">
                <img src="https://picsum.photos/id/175/400/600" class="w-full aspect-[2/3] object-cover">
                <div class="p-3 text-center text-sm">剧集标题</div>
            </div>
            <div class="card rounded-xl overflow-hidden bg-gray-900">
                <img src="https://picsum.photos/id/176/400/600" class="w-full aspect-[2/3] object-cover">
                <div class="p-3 text-center text-sm">剧集标题</div>
            </div>
            <div class="card rounded-xl overflow-hidden bg-gray-900">
                <img src="https://picsum.photos/id/177/400/600" class="w-full aspect-[2/3] object-cover">
                <div class="p-3 text-center text-sm">剧集标题</div>
            </div>
            <div class="card rounded-xl overflow-hidden bg-gray-900">
                <img src="https://picsum.photos/id/178/400/600" class="w-full aspect-[2/3] object-cover">
                <div class="p-3 text-center text-sm">剧集标题</div>
            </div>
            <div class="card rounded-xl overflow-hidden bg-gray-900">
                <img src="https://picsum.photos/id/179/400/600" class="w-full aspect-[2/3] object-cover">
                <div class="p-3 text-center text-sm">剧集标题</div>
            </div>
        </div>
    </section>

    <!-- 导航链接 -->
    <section class="p-6 bg-gray-900/50 rounded-2xl mb-10">
        <h2 class="text-xl font-semibold mb-4">影视导航入口</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
            <a href="#" class="p-4 bg-gray-800 hover:bg-gray-700 rounded-xl flex items-center gap-3">
                <i class="fa fa-link text-red-500 text-xl"></i>
                <span>稳定影视源 1</span>
            </a>
            <a href="#" class="p-4 bg-gray-800 hover:bg-gray-700 rounded-xl flex items-center gap-3">
                <i class="fa fa-link text-red-500 text-xl"></i>
                <span>稳定影视源 2</span>
            </a>
            <a href="#" class="p-4 bg-gray-800 hover:bg-gray-700 rounded-xl flex items-center gap-3">
                <i class="fa fa-link text-red-500 text-xl"></i>
                <span>稳定影视源 3</span>
            </a>
        </div>
    </section>

</div>

<!-- 底部 -->
<footer class="text-center py-8 text-gray-500 text-sm">
    <p>星云影视 © 所有资源均来源于互联网公开平台，仅提供导航服务</p>
</footer>

</body>
</html>
